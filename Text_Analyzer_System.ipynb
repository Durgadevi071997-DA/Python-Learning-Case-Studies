          "text": [
            "Enter the string :Welcome To All123@\n",
            "5 7 3 3\n"
          ]
        }
      ],
      "source": [
        "text = input(\"Enter the string :\").lower() #Welgome To All123@\n",
        "\n",
        "v = c = d = sc = 0\n",
        "\n",
        "for letter in text:\n",
        "\n",
        "  if letter in \"aeiou\":\n",
        "    v +=1\n",
        "  elif letter.isalpha():\n",
        "    c +=1\n",
        "  elif letter.isdigit():\n",
        "    d +=1\n",
        "  else:\n",
        "    sc += 1\n",
        "\n",
        "print(v,c,d,sc)"
      ]
    }
  ]
